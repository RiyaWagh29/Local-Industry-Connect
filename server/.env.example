# Server Configuration
PORT=5001
NODE_ENV=production

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name

# Auth Configuration
JWT_SECRET=replace_with_a_long_random_secret

# Frontend origin allowed to call the API
CORS_ORIGIN=https://your-frontend-domain.com

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_RESOURCE_BUCKET=Resources
SUPABASE_AVATAR_BUCKET=Profile photos
SUPABASE_VERIFICATION_BUCKET=Verification documents

# Optional Integrations
ZOOM_TOKEN=

# SMTP Configuration for OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password
SMTP_FROM=your_email@gmail.com

# Emergency/demo fallback: returns OTP in API response if SMTP fails.
# Keep false in production unless you intentionally need a temporary demo bypass.
ALLOW_OTP_FALLBACK=false
